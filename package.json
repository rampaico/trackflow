{
  "name": "@trackflow/shopify-app",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm start",
    "setup": "prisma generate && prisma migrate deploy",
    "typecheck": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@remix-run/node": "^2.9.2",
    "@remix-run/react": "^2.9.2",
    "@remix-run/serve": "^2.9.2",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.3.1",
    "@shopify/shopify-app-remix": "^3.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.0.5",
    "isbot": "^4.4.0",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.9.2",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "prisma": "^5.13.0",
    "typescript": "^5.5.4",
    "vite": "^5.1.0",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
