// TrackFlow — Bulk CSV Tracking Import for Shopify
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify App session storage (required by @shopify/shopify-app-session-storage-prisma)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// One import job = one CSV upload
model ImportJob {
  id              String      @id @default(cuid())
  shop            String
  filename        String
  status          String       @default("PENDING")
  totalRows       Int         @default(0)
  successCount    Int         @default(0)
  failedCount     Int         @default(0)
  skippedCount    Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  rows            ImportRow[]
}

// One row = one order fulfillment attempt
model ImportRow {
  id              String      @id @default(cuid())
  jobId           String
  job             ImportJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex        Int
  orderName       String      // e.g. "#1001"
  orderId         String?     // Shopify order GID (resolved during import)
  trackingNumber  String
  carrier         String
  carrierUrl      String?
  status          String      @default("PENDING")
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime    @default(now())
}

// Merchant billing/usage tracking
model MerchantUsage {
  id                    String    @id @default(cuid())
  shop                  String    @unique
  plan                  String    @default("FREE")
  ordersImportedThisCycle Int     @default(0)
  cycleStartDate        DateTime  @default(now())
  totalOrdersImported   Int       @default(0)
  shopifySubscriptionId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ── Auto-Import: Email Forwarding ─────────────────────────────────────────────

// Unique email address per shop (import-{token}@mail.trackflow.app)
// When an email arrives at that address, the attachment is auto-imported.
model EmailImportAddress {
  id          String    @id @default(cuid())
  shop        String    @unique
  token       String    @unique   // random, URL-safe (e.g. "x7k2p9")
  email       String    @unique   // import-{token}@mail.trackflow.app
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Auto-Import: Drive / Dropbox Connection ────────────────────────────────────

model DriveConnection {
  id            String    @id @default(cuid())
  shop          String
  provider      String    // "google_drive" | "dropbox"
  accessToken   String    // encrypted at rest
  refreshToken  String?   // for Google Drive PKCE refresh
  expiresAt     DateTime?
  folderPath    String    // Drive folder ID or Dropbox path to watch
  folderName    String?   // human-readable label
  lastPolledAt  DateTime?
  lastImportAt  DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ── Auto-Import: Job source tracking ─────────────────────────────────────────

// Extend ImportJob with auto-import source
// Added as separate model to avoid migration breaking existing jobs
model ImportJobSource {
  id            String    @id @default(cuid())
  jobId         String    @unique
  source        String    // "manual" | "email" | "google_drive" | "dropbox"
  sourceRef     String?   // e.g. email Message-Id or Drive file ID
  createdAt     DateTime  @default(now())
}

// Status values stored as strings:
// ImportStatus: PENDING, RUNNING, COMPLETED, COMPLETED_WITH_ERRORS, FAILED
// RowStatus: PENDING, SUCCESS, FAILED, SKIPPED
// PlanTier: FREE, PRO
